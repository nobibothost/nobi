<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Premium IME Test Lab"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#37474F"
            android:layout_marginBottom="24dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Standard Chat (Auto Caps &amp; Text)"
            android:textColor="#546E7A"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/et_test_standard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Type a message..."
            android:minHeight="48dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:elevation="2dp"
            android:inputType="textCapSentences|textAutoCorrect"
            android:imeOptions="actionSend"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Search Context (Shows Search Icon)"
            android:textColor="#546E7A"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/et_test_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search here..."
            android:minHeight="48dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:elevation="2dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Phone Dialer (Triggers Number Pad)"
            android:textColor="#546E7A"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/et_test_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter phone number..."
            android:minHeight="48dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:elevation="2dp"
            android:inputType="phone"
            android:imeOptions="actionDone"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. Multi-line (Forces standard Enter/Return)"
            android:textColor="#546E7A"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/et_test_multiline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Write a paragraph...\nLine 2\nLine 3"
            android:minHeight="100dp"
            android:gravity="top|start"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:elevation="2dp"
            android:inputType="textMultiLine|textCapSentences"
            android:layout_marginBottom="20dp"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5. Email Address"
            android:textColor="#546E7A"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/et_test_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="example@domain.com"
            android:minHeight="48dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:elevation="2dp"
            android:inputType="textEmailAddress"
            android:imeOptions="actionNext"
            android:layout_marginBottom="40dp"/> </LinearLayout>
</ScrollView>
